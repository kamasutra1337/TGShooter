{
  "name": "tg-shooter-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Authoritative game server for TG Shooter (rooms, tick sim, lag comp, TON pot)",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "gen:copy": "cp ../contracts/build/match_escrow_MatchEscrow.ts src/ton/MatchEscrow.gen.ts",
    "test": "tsx test/integration.ts",
    "test:escrow": "tsx test/escrow.ts",
    "test:rooms": "tsx test/rooms.ts"
  },
  "dependencies": {
    "@ton/core": "^0.60.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@ton/sandbox": "^0.24.0",
    "@ton/test-utils": "^0.5.0",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
